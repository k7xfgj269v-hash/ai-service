# Runtime
NODE_ENV=development
PORT=3031
PUBLIC_DOMAIN=localhost
HTTP_BODY_LIMIT=1mb
CORS_ORIGINS=http://localhost:3031
SWAGGER_ENABLED=true

# Required in production. Use a long random value.
ADMIN_API_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# Single Expert answer model
EXPERT_API_KEY=
EXPERT_API_BASE_URL=https://api.example.com/v1
EXPERT_MODEL=your-expert-model
EXPERT_TEMPERATURE=0.2
EXPERT_MAX_TOKENS=8192

# Retrieval embedding model
EMBEDDING_API_KEY=
EMBEDDING_API_BASE_URL=https://api.example.com/v1
EMBEDDING_MODEL=text-embedding-v3

# Enterprise WeChat application
WORK_WEIXIN_ENABLED=false
WORK_WEIXIN_CORP_ID=
WORK_WEIXIN_CORP_SECRET=
WORK_WEIXIN_AGENT_ID=
WORK_WEIXIN_TOKEN=
WORK_WEIXIN_ENCODING_AES_KEY=

# Enterprise WeChat zone and internal sync
WORK_WEIXIN_ABILITY_ID=
WORK_WEIXIN_SYNC_TOKEN=
WORK_WEIXIN_ALLOW_TEST=false

# Chat-record knowledge-base sync
KNOWLEDGE_BASE_AUTO_SYNC=false
SYNC_INTERVAL_MINUTES=30
MIN_RECORDS_FOR_UPDATE=50
