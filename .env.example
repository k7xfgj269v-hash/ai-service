# =============================================================================
# ai-service — Environment Variables
# Copy this file to .env and fill in real values before running.
# =============================================================================

# --- Server ------------------------------------------------------------------
# HTTP port the NestJS app listens on
PORT=3031
# Public-facing domain (used in startup log for callback URL reference)
PUBLIC_DOMAIN=yourdomain.com

# --- Redis -------------------------------------------------------------------
# Redis connection URL — REQUIRED. App will fail to start if unset.
REDIS_URL=redis://localhost:6379

# --- DeepSeek AI (Primary LLM) ----------------------------------------------
# DeepSeek API key — REQUIRED
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# OpenAI-compatible base URL for DeepSeek
OPENAI_API_BASE_URL=https://api.deepseek.com
# Model name for standard chat
AI_MODEL=deepseek-chat

# --- Qwen (Expert / HR Mode) ------------------------------------------------
# Optional — falls back to DEEPSEEK_API_KEY and OPENAI_API_BASE_URL if blank
QWEN_API_KEY=
QWEN_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# --- Embedding ---------------------------------------------------------------
# Optional — falls back to DEEPSEEK_API_KEY and OPENAI_API_BASE_URL if blank
EMBEDDING_API_KEY=
EMBEDDING_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3

# --- WeChat Work (Enterprise WeChat) ----------------------------------------
# Set to true to enable WeChat Work integration
WORK_WEIXIN_ENABLED=false
WORK_WEIXIN_CORP_ID=wwYOURCORPID
WORK_WEIXIN_CORP_SECRET=your-corp-secret
WORK_WEIXIN_AGENT_ID=1000001
# Callback verification token (configured in WeChat Work developer console)
WORK_WEIXIN_TOKEN=your-callback-token
# 43-character AES key for message encryption/decryption
WORK_WEIXIN_ENCODING_AES_KEY=your-43-char-aes-key

# --- WeChat Work Zone Spec (optional, for spec-callback service) -------------
WORK_WEIXIN_ABILITY_ID=
WORK_WEIXIN_SYNC_TOKEN=
# Local-debug only: allow the unsigned `test_signature` callback path. Leave
# false in production — it bypasses WeChat signature verification entirely.
WORK_WEIXIN_ALLOW_TEST=false

# --- Feature Flags -----------------------------------------------------------
# Default mode for AI responses (true = HR expert mode using Qwen)
HR_EXPERT_MODE=true
# Enable automatic sync of WeChat chat records into knowledge base
KNOWLEDGE_BASE_AUTO_SYNC=false
# How often to sync (minutes) — only used when KNOWLEDGE_BASE_AUTO_SYNC=true
SYNC_INTERVAL_MINUTES=30
# Minimum number of new records before triggering KB update
MIN_RECORDS_FOR_UPDATE=50
